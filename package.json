{
  "name": "media-manager",
  "version": "0.1.0",
  "description": "SaaS platform for intelligent Meta Ads campaign management with AI-powered suggestions",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
